# Normalise line endings so the repo always stores LF, regardless of the
# operating system a contributor is on. Without this, editing on Windows
# rewrites whole files as CRLF and every diff looks like a total rewrite.
* text=auto eol=lf

# Binary files must never be line-ending converted.
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
